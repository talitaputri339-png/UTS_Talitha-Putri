.dashboard-cards {
    display: flex;
    gap: 20px;
    margin: 20px;
}

.dash-card {
    background: #2e7d32;
    color: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(0,0,0,.2);
    flex: 1;
}

.dash-title {
    font-size: 14px;
    opacity: 0.9;
}

.dash-value {
    font-size: 32px;
    font-weight: bold;
}
